{
  "name": "tradelingo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "start": "bun server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc",
    "lint": "eslint src server api tests",
    "lint:fix": "eslint src server api tests --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\" \"api/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\" \"api/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:load": "vitest run tests/load.test.ts --no-file-parallelism"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "lucide-react": "^0.574.0",
    "mongodb": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.15.0",
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.9",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.6",
    "autocannon": "^8.0.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.15.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^2.1.6"
  }
}
