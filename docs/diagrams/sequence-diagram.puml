@startuml Student-Course-Interaction
skinparam shadowing false
skinparam defaultFontSize 11
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 200
skinparam padding 5

title Student Course Interaction – Sequence Diagram

actor "Alice\n(Student)" as alice
participant "Student" as student
participant "Course\n(cs1)" as course
participant "Question" as question
participant "Dr. Turner\n(Professor)" as prof

== Student Creation ==

create student
alice -> student : <<create>> Student("Alice")
student --> alice : alice (name="Alice", enrolled_courses=[])

== Course Enrollment ==

alice -> student : enroll(cs1)
student -> course : append to enrolled_courses
student --> alice : cs1 added to enrolled_courses

== Asking a Question in Class ==

create question
alice -> question : <<create>> Question("What is polymorphism?")
question --> alice : question (text="What is polymorphism?")

alice -> course : ask_question(alice, cs1, question)
course --> alice : "Alice asks in cs1: What is polymorphism?"

== Professor Answers ==

course -> prof : forward question
prof -> prof : prepare explanation
prof --> alice : "Dr. Turner answers: ... (explanation of polymorphism)"

@enduml
